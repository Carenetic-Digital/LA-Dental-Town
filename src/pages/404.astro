---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — LA Dental Town" noindex={true}>
  <section class="bg-cream min-h-[60vh] flex items-center justify-center py-24 px-4">
    <div class="text-center max-w-md mx-auto">
      <p class="font-display text-8xl font-bold text-green-dark/20 leading-none mb-6">404</p>
      <h1 class="font-display font-bold text-2xl sm:text-3xl text-green-dark mb-4">Page Not Found</h1>
      <p class="font-body text-base text-ink/60 leading-relaxed mb-8">
        Sorry, the page you're looking for doesn't exist or may have moved. Let us help you find what you need.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-green-mid hover:bg-green-dark text-white font-body font-semibold px-7 py-3.5 rounded-full transition-colors duration-200">
          Return Home
        </a>
        <a
          href="/contents/appointments/"
          class="inline-flex items-center justify-center gap-2 border-2 border-green-dark text-green-dark hover:bg-green-dark hover:text-white font-body font-semibold px-7 py-3.5 rounded-full transition-colors duration-200">
          Book Appointment
        </a>
      </div>
      <div class="mt-10 pt-8 border-t border-neutral-200">
        <p class="font-body text-sm text-ink/40 mb-4">Or find what you're looking for:</p>
        <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 font-body text-sm text-green-mid" aria-label="Helpful links">
          <a href="/services/" class="hover:text-green-dark transition-colors">Services</a>
          <a href="/provider/" class="hover:text-green-dark transition-colors">Our Doctors</a>
          <a href="/testimonials/" class="hover:text-green-dark transition-colors">Testimonials</a>
          <a href="/blog/" class="hover:text-green-dark transition-colors">Blog</a>
          <a href="/contactus/" class="hover:text-green-dark transition-colors">Contact</a>
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>
