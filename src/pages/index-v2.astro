---
import BaseLayout from '../layouts/BaseLayout.astro';

const seoTitle = 'LA Dental Town | Family Dentistry in East Los Angeles, CA';
const seoDescription = 'Top-rated family, cosmetic & specialty dental practice in East Los Angeles. General dentistry, Invisalign, dental implants, pediatric care & more. Walk-ins welcome. Se Habla Español.';

const services = [
  {
    title: 'General & Family Dentistry',
    description: 'Comprehensive care for patients of all ages — cleanings, exams, crowns & more.',
    href: '/services/general-family-dentistry/',
    number: '01',
  },
  {
    title: 'Cosmetic Dentistry',
    description: 'Veneers, Invisalign, teeth whitening & smile makeovers — beautiful, natural results.',
    href: '/services/cosmetic-dentistry/',
    number: '02',
  },
  {
    title: 'Dental Implants',
    description: 'The only restoration that preserves jawbone — permanent, natural-looking teeth.',
    href: '/services/dental-implants/',
    number: '03',
  },
  {
    title: 'Oral Surgery',
    description: 'Expert wisdom teeth removal & extractions by our on-staff oral surgeon.',
    href: '/services/oral-surgery/',
    number: '04',
  },
  {
    title: 'Endodontics',
    description: 'Root canals performed by our board-certified, Columbia-trained endodontist.',
    href: '/services/endodontics/',
    number: '05',
  },
  {
    title: 'Pediatric Dentistry',
    description: 'Gentle, fun care for kids from their first visit — play area & PlayStation on-site.',
    href: '/services/pediatric-dentistry/',
    number: '06',
  },
];

const testimonials = [
  {
    text: "Dr. Wu and her staff are very courteous and professional — they make you feel so comfortable you actually forget you are at the dentist.",
    author: "Frank G.",
    source: "Yelp",
    stars: 5,
  },
  {
    text: "This is truly a one stop shop; they have it all. The office is clean, the staff are friendly and knowledgeable.",
    author: "Paul C.",
    source: "Google",
    stars: 5,
  },
  {
    text: "Dr. Jen and Dr. Wu are both super friendly and professional and genuinely care about their patients and their comfort. I recommend them for all of your dental needs.",
    author: "Yesenia T.",
    source: "Yelp",
    stars: 5,
  },
  {
    text: "They took great care of us! Dr Wu, Dr Jen, Dr Tiff and their entire team are awesome!",
    author: "Yogi P.",
    source: "Google",
    stars: 5,
  },
];

const blogPosts = [
  {
    title: "The Benefits of Digital Impression Scans Over Traditional Dental Putty",
    href: "/blog/the-benefits-of-digital-impression-scans-over-traditional-dental-putty/",
    tag: "Technology",
    gradient: '#1D4D2F, #3A7D44',
  },
  {
    title: "Why Same-Day Crowns Are the Best Option for Busy Professionals",
    href: "/blog/why-same-day-crowns-are-the-best-option-for-busy-professionals/",
    tag: "Restorative",
    gradient: '#163232, #1D4D2F',
  },
  {
    title: "Are You a Candidate for Dental Implants?",
    href: "/blog/are-you-a-candidate-for-dental-implants/",
    tag: "Implants",
    gradient: '#3A7D44, #C9A84C',
  },
];
---

<BaseLayout title={seoTitle} description={seoDescription}>

  <!-- ──────────────────────────────────────────────────────────────────────
       SECTION 1: Hero (V2 — Light editorial split layout)
  ─────────────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-cream" aria-label="Welcome to LA Dental Town">

    <!-- Decorative arc behind right panel -->
    <div class="absolute top-0 right-0 w-1/2 h-full bg-green-dark hidden lg:block" aria-hidden="true"></div>
    <!-- Subtle grain on green side -->
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-[0.03] hidden lg:block" style="background-image: radial-gradient(circle, rgba(255,255,255,0.9) 1px, transparent 1px); background-size: 24px 24px" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 min-h-[88vh] lg:min-h-screen items-center">

        <!-- Left: Editorial typography -->
        <div class="py-24 lg:py-32 lg:pr-16">
          <p class="font-body text-xs sm:text-sm uppercase tracking-widest text-green-mid mb-6">East Los Angeles, California</p>
          <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl text-green-dark leading-[1.06] mb-8">
            Healthy<br>
            <span class="relative inline-block">
              Smiles.
              <!-- Gold underline accent -->
              <span class="absolute -bottom-1 left-0 w-full h-1 bg-gold rounded-full" aria-hidden="true"></span>
            </span><br>
            <span class="text-green-mid">Happy Lives.</span>
          </h1>
          <p class="font-body text-lg sm:text-xl text-ink/65 leading-relaxed mb-10 max-w-md">
            Quality care for the whole family — general, cosmetic &amp; specialty dentistry serving East Los Angeles and surrounding communities.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/contents/appointments/"
              class="inline-flex items-center gap-2 bg-green-dark hover:bg-green-mid text-white font-body font-semibold px-8 py-4 rounded-full text-base transition-all duration-200 shadow-lg shadow-green-dark/25">
              Book Appointment
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
            <a
              href="tel:+13238870088"
              class="inline-flex items-center gap-2 border-2 border-green-dark/30 hover:border-green-dark text-ink hover:text-green-dark font-body font-medium px-8 py-4 rounded-full text-base transition-all duration-200">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              (323) 887-0088
            </a>
          </div>

          <!-- Quick trust badges -->
          <div class="mt-12 flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-2 bg-white border border-neutral-200 rounded-full px-4 py-2 font-body text-xs font-semibold text-ink">
              <span class="text-gold text-sm" aria-hidden="true">★</span> 4.9 · 305 Reviews
            </span>
            <span class="inline-flex items-center gap-2 bg-white border border-neutral-200 rounded-full px-4 py-2 font-body text-xs font-semibold text-ink">
              Walk-Ins Welcome
            </span>
            <span class="inline-flex items-center gap-2 bg-white border border-neutral-200 rounded-full px-4 py-2 font-body text-xs font-semibold text-ink">
              Se Habla Español
            </span>
          </div>
        </div>

        <!-- Right: Video placeholder -->
        <div class="lg:pl-8 xl:pl-12 pb-16 pt-8 lg:py-16 flex items-center">
          <div class="relative w-full rounded-3xl overflow-hidden" style="aspect-ratio: 16/10;">
            <!-- Gradient background standing in for video -->
            <div class="absolute inset-0" style="background: linear-gradient(160deg, #163232 0%, #1D4D2F 55%, #3A7D44 100%)" aria-hidden="true"></div>
            <!-- Subtle dot pattern -->
            <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.9) 1px, transparent 1px); background-size: 20px 20px" aria-hidden="true"></div>
            <!-- Play button overlay -->
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-4">
              <button
                class="w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-white/15 border-2 border-white/40 flex items-center justify-center backdrop-blur-sm hover:bg-white/25 hover:scale-105 transition-all duration-200"
                aria-label="Play video">
                <svg class="w-6 h-6 sm:w-8 sm:h-8 text-white ml-1" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
              <p class="font-body text-xs text-white/50 uppercase tracking-widest">Video coming soon</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ──────────────────────────────────────────────────────────────────────
       SECTION 2: Gold stats marquee bar
  ─────────────────────────────────────────────────────────────────────── -->
  <div class="bg-green-dark py-6 overflow-hidden" aria-hidden="true">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ul class="flex flex-wrap justify-center lg:justify-between gap-x-10 gap-y-3 list-none m-0 p-0">
        {[
          { num: '6', label: 'Specialists On Staff' },
          { num: '4.9★', label: 'Google Rating' },
          { num: '20+', label: 'Years in East LA' },
          { num: 'PPO', label: '& Denti-Cal Accepted' },
          { num: '305+', label: 'Verified Reviews' },
        ].map(item => (
          <li class="flex items-center gap-3">
            <span class="font-display font-bold text-xl text-gold">{item.num}</span>
            <span class="font-body text-xs text-white/60 uppercase tracking-wider">{item.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>


  <!-- ──────────────────────────────────────────────────────────────────────
       SECTION 3: Services — numbered list layout
  ─────────────────────────────────────────────────────────────────────── -->
  <section class="bg-white py-20 sm:py-28" aria-labelledby="services-heading-v2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header with gold accent bar -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5 mb-14">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-12 bg-gold"></div>
            <p class="font-body text-xs uppercase tracking-widest text-gold">What We Offer</p>
          </div>
          <h2 id="services-heading-v2" class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-green-dark leading-tight">
            Everything Under<br class="hidden sm:block"> One Roof
          </h2>
        </div>
        <a href="/services/" class="self-start sm:self-auto shrink-0 inline-flex items-center gap-2 border-2 border-green-dark text-green-dark hover:bg-green-dark hover:text-white font-body font-semibold px-7 py-3 rounded-full transition-all duration-200 text-sm">
          All Services
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Numbered service rows -->
      <ul class="list-none m-0 p-0 divide-y divide-neutral-100">
        {services.map((s) => (
          <li>
            <a
              href={s.href}
              class="group flex items-center gap-6 py-6 sm:py-7 hover:bg-cream/60 -mx-4 px-4 rounded-xl transition-colors duration-200">
              <span class="font-display font-bold text-3xl sm:text-4xl text-green-dark/15 group-hover:text-gold transition-colors duration-200 w-12 shrink-0 text-right leading-none">{s.number}</span>
              <div class="flex-grow min-w-0">
                <h3 class="font-display font-semibold text-lg sm:text-xl text-green-dark group-hover:text-green-mid transition-colors leading-tight mb-1">{s.title}</h3>
                <p class="font-body text-sm text-ink/55 leading-relaxed">{s.description}</p>
              </div>
              <svg class="w-5 h-5 text-ink/20 group-hover:text-green-mid group-hover:translate-x-1 transition-all duration-200 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

    </div>
  </section>


  <!-- ──────────────────────────────────────────────────────────────────────
       SECTION 4: About — bold asymmetric layout
  ─────────────────────────────────────────────────────────────────────── -->
  <section class="bg-cream py-20 sm:py-28 overflow-hidden" aria-labelledby="about-heading-v2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-0 items-stretch">

        <!-- Left: Large green panel -->
        <div class="lg:col-span-5 bg-green-dark rounded-3xl p-8 sm:p-12 flex flex-col justify-between gap-8">
          <div>
            <div class="flex items-center gap-3 mb-8">
              <div class="h-px w-8 bg-gold"></div>
              <p class="font-body text-xs uppercase tracking-widest text-gold">Our Practice</p>
            </div>
            <h2 id="about-heading-v2" class="font-display font-bold text-3xl sm:text-4xl text-white leading-tight mb-6">
              Trusted Care for<br>Every Smile
            </h2>
            <p class="font-body text-base text-white/70 leading-relaxed">
              The dentists at LA Dental Town emphasize patient comfort and staying up-to-date with the latest advances in dental technology. Our caring, compassionate team takes a patient-centered approach — listening to your concerns and ensuring comfort throughout every visit.
            </p>
          </div>

          <!-- Feature callout -->
          <div class="border-t border-white/15 pt-8 space-y-4">
            {[
              'Optional oral sedation & nitrous oxide',
              'Blankets, pillows & flatscreen TVs',
              'Kids\' play area & PlayStation',
              'Walk-ins always welcome',
            ].map(item => (
              <div class="flex items-center gap-3">
                <div class="w-5 h-5 rounded-full bg-gold/20 border border-gold/40 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="font-body text-sm text-white/75">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Stats + Text + CTA -->
        <div class="lg:col-span-7 lg:pl-14 flex flex-col justify-center gap-8">

          <!-- Stats grid (moved from hero) -->
          <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4 gap-3">
            <div class="bg-white rounded-2xl p-5 border border-neutral-200 flex flex-col gap-1">
              <p class="font-display font-bold text-3xl text-green-dark leading-none">6</p>
              <p class="font-body text-xs text-ink/55 leading-snug">Specialists on staff</p>
            </div>
            <div class="bg-green-dark rounded-2xl p-5 flex flex-col gap-1">
              <p class="font-display font-bold text-3xl text-white leading-none">4.9<span class="text-gold text-xl">★</span></p>
              <p class="font-body text-xs text-white/65 leading-snug">Google Rating</p>
            </div>
            <div class="bg-white rounded-2xl p-5 border border-neutral-200 flex flex-col gap-1">
              <p class="font-display font-bold text-3xl text-green-dark leading-none">20+</p>
              <p class="font-body text-xs text-ink/55 leading-snug">Years in East LA</p>
            </div>
            <div class="bg-cream rounded-2xl p-5 border border-neutral-200 flex flex-col gap-1">
              <p class="font-display font-bold text-lg text-green-dark leading-tight">Top Rated</p>
              <p class="font-body text-xs text-ink/55 leading-snug">America's Top Dentists</p>
            </div>
          </div>

          <div class="space-y-5 font-body text-base text-ink/70 leading-relaxed">
            <p class="text-lg text-ink/80">
              With outstanding dental education, cutting-edge technology, and an emphasis on a positive patient experience, the dentists at LA Dental Town are changing the way people think about visiting the dentist.
            </p>
            <p>
              We offer extensive amenities to keep you comfortable and offer extensive same-day and flexible appointment options. Our team is bilingual — <strong class="text-ink">Se Habla Español</strong> — and we welcome walk-in patients of all ages.
            </p>
          </div>

          <!-- Award highlight -->
          <div class="rounded-2xl p-6 border-2 border-gold/30 bg-white flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-gold/15 flex items-center justify-center shrink-0">
              <span class="text-gold text-2xl leading-none" aria-hidden="true">★</span>
            </div>
            <div>
              <p class="font-display font-semibold text-base text-green-dark mb-1">Top Rated Dentists in Los Angeles</p>
              <p class="font-body text-sm text-ink/60 leading-relaxed">Drs. Jennifer Wu and Margaret Wu featured in <em>Time Magazine</em> — America's Top Dentists, multiple years running.</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-4">
            <a href="/contents/appointments/" class="inline-flex items-center gap-2 bg-green-mid hover:bg-green-dark text-white font-body font-semibold px-7 py-3.5 rounded-full transition-colors duration-200">
              Book an Appointment
            </a>
            <a href="/provider/" class="inline-flex items-center gap-2 text-green-dark hover:text-green-mid font-body font-semibold px-7 py-3.5 rounded-full border-2 border-green-dark/30 hover:border-green-mid transition-colors duration-200">
              Meet the Doctors
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ──────────────────────────────────────────────────────────────────────
       SECTION 5: Testimonials — dark green background (inverted from V1)
  ─────────────────────────────────────────────────────────────────────── -->
  <section class="bg-green-dark py-20 sm:py-28" aria-labelledby="testimonials-heading-v2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-5 mb-14">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-12 bg-gold"></div>
            <p class="font-body text-xs uppercase tracking-widest text-gold">Patient Reviews</p>
          </div>
          <h2 id="testimonials-heading-v2" class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-white leading-tight">
            What Our Patients Say
          </h2>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <span class="text-gold text-xl" aria-label="4.9 star rating">★★★★★</span>
          <span class="font-body font-semibold text-white text-base">4.9</span>
          <span class="font-body text-white/50 text-sm">· 305 reviews</span>
        </div>
      </div>

      <!-- Featured quote -->
      <div class="mb-6 bg-white/10 rounded-3xl p-8 sm:p-10 border border-white/15">
        <div class="text-gold text-2xl mb-4" aria-label="5 stars">★★★★★</div>
        <blockquote class="font-display font-semibold text-xl sm:text-2xl text-white leading-relaxed mb-6">
          "Dr. Wu and her staff are very courteous and professional — they make you feel so comfortable you actually forget you are at the dentist."
        </blockquote>
        <div class="flex items-center gap-3">
          <span class="font-body font-semibold text-sm text-white">Frank G.</span>
          <span class="font-body text-xs text-white/50 bg-white/10 rounded-full px-3 py-1">Yelp</span>
        </div>
      </div>

      <!-- Secondary quotes grid -->
      <ul class="grid grid-cols-1 sm:grid-cols-3 gap-4 list-none m-0 p-0">
        {testimonials.slice(1).map((t) => (
          <li class="bg-cream rounded-2xl p-6 flex flex-col gap-4">
            <div class="flex items-center gap-1 text-gold" aria-label={`${t.stars} stars`}>
              {'★'.repeat(t.stars)}
            </div>
            <blockquote class="font-body text-sm text-ink/80 leading-relaxed flex-grow">
              "{t.text}"
            </blockquote>
            <footer class="flex items-center justify-between pt-2 border-t border-neutral-200/60">
              <cite class="font-body font-semibold text-xs text-ink not-italic">{t.author}</cite>
              <span class="font-body text-xs text-ink/50 bg-white border border-neutral-200 rounded-full px-3 py-1">{t.source}</span>
            </footer>
          </li>
        ))}
      </ul>

      <div class="text-center mt-10">
        <a href="/testimonials/" class="inline-flex items-center gap-2 border-2 border-white/30 hover:border-white text-white font-body font-semibold px-7 py-3.5 rounded-full transition-colors duration-200 text-sm">
          Read All Reviews
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>


  <!-- ──────────────────────────────────────────────────────────────────────
       SECTION 6: Blog Preview — editorial layout
  ─────────────────────────────────────────────────────────────────────── -->
  <section class="bg-white py-20 sm:py-28" aria-labelledby="blog-heading-v2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-5 mb-12">
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class="h-px w-12 bg-gold"></div>
            <p class="font-body text-xs uppercase tracking-widest text-gold">Dental Health</p>
          </div>
          <h2 id="blog-heading-v2" class="font-display font-bold text-3xl sm:text-4xl text-green-dark leading-tight">
            From Our Blog
          </h2>
        </div>
        <a href="/blog/" class="self-start sm:self-auto font-body text-sm font-semibold text-green-mid hover:text-green-dark flex items-center gap-1.5 transition-colors shrink-0">
          View all posts
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Large feature + two secondary -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">

        <!-- Feature card (large) -->
        <a href={blogPosts[0].href} class="group lg:col-span-7 rounded-3xl overflow-hidden border border-neutral-200 hover:border-green-mid/40 hover:shadow-xl transition-all duration-200 flex flex-col">
          <div
            class="h-56 sm:h-72 flex items-end p-6"
            style={`background: linear-gradient(135deg, ${blogPosts[0].gradient})`}
            aria-hidden="true">
            <span class="inline-block font-body text-xs font-semibold text-white/90 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1.5">
              {blogPosts[0].tag}
            </span>
          </div>
          <div class="p-7 bg-white flex-grow flex flex-col gap-4">
            <h3 class="font-display font-semibold text-xl sm:text-2xl text-green-dark leading-snug group-hover:text-green-mid transition-colors">
              {blogPosts[0].title}
            </h3>
            <span class="mt-auto inline-flex items-center gap-1.5 font-body text-sm font-semibold text-green-mid">
              Read more
              <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>

        <!-- Two secondary cards stacked -->
        <div class="lg:col-span-5 flex flex-col gap-5">
          {blogPosts.slice(1).map((post) => (
            <a href={post.href} class="group flex rounded-2xl overflow-hidden border border-neutral-200 hover:border-green-mid/40 hover:shadow-xl transition-all duration-200 bg-white flex-1">
              <div
                class="w-28 shrink-0"
                style={`background: linear-gradient(135deg, ${post.gradient})`}
                aria-hidden="true">
              </div>
              <div class="p-5 flex flex-col justify-between gap-3 flex-grow">
                <div>
                  <span class="inline-block font-body text-xs font-semibold text-green-mid bg-green-dark/8 rounded-full px-2.5 py-1 mb-2">{post.tag}</span>
                  <h3 class="font-display font-semibold text-sm sm:text-base text-green-dark leading-snug group-hover:text-green-mid transition-colors line-clamp-3">
                    {post.title}
                  </h3>
                </div>
                <span class="inline-flex items-center gap-1 font-body text-xs font-semibold text-green-mid">
                  Read more
                  <svg class="w-3 h-3 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>

      </div>
    </div>
  </section>


