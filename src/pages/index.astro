        <!-- CTA card -->
        <div class="bg-white/10 rounded-3xl p-8 sm:p-10 border border-white/20">
          <h3 class="font-display font-semibold text-2xl text-white mb-3">Ready to get started?</h3>
          <p class="font-body text-white/70 text-sm leading-relaxed mb-7">
