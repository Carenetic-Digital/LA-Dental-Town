---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Family Dentistry & Cosmetic Dentistry in East Los Angeles, CA — LA Dental Town',
  image,
  noindex = false,
} = Astro.props;

// Site-wide structured data
const organizationData = {
  name: "LA Dental Town",
  url: Astro.site?.href,
  logo: new URL('/images/logo.png', Astro.site).href,
  telephone: "(323) 887-0088",
  email: "ladentaltown13@gmail.com",
  address: {
    streetAddress: "5262 E Beverly Blvd",
    addressLocality: "East Los Angeles",
    addressRegion: "CA",
    postalCode: "90022",
    addressCountry: "US",
  },
  openingHours: "Mo-Fr 08:30-17:30",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect to external origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts: Playfair Display + Lato -->
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Lato:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <meta name="theme-color" content="#1D4D2F" />

    <SEOHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
    />

    <StructuredData type="Organization" data={organizationData} />
  </head>
  <body class="font-body antialiased">

    <a href="#main-content" class="skip-link">Skip to content</a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- ── Sticky "Book Now" button (sitewide, lower-right) ─────────────────
         TODO: Replace href with booking widget trigger once embed code arrives
    ─────────────────────────────────────────────────────────────────────── -->
    <a
      href="/contents/appointments/"
      class="fixed bottom-5 right-5 z-40 flex items-center gap-2 bg-green-mid hover:bg-green-dark text-white font-body font-semibold text-sm px-5 py-3 rounded-full shadow-xl hover:shadow-2xl transition-all duration-200"
      aria-label="Book an appointment">
      <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11zM7 11h5v5H7z"/>
      </svg>
      Book Now
    </a>

    <!-- ── Floating Google Reviews badge (lower-left) ──────────────────────
         TODO: Update href to the practice's verified Google Business profile URL
    ─────────────────────────────────────────────────────────────────────── -->
    <a
      href="https://www.google.com/search?q=LA+Dental+Town+East+Los+Angeles+reviews"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-5 left-5 z-40 flex items-center gap-3 bg-white hover:bg-neutral-50 text-ink shadow-xl hover:shadow-2xl rounded-2xl px-4 py-3 transition-all duration-200"
      aria-label="View our 4.9-star Google Reviews">
      <!-- Google G icon -->
      <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-white font-bold text-sm" style="background: linear-gradient(135deg, #4285F4 25%, #34A853 50%, #FBBC05 75%, #EA4335 100%)">G</div>
      <div class="leading-tight">
        <p class="text-[10px] text-ink/50 font-body uppercase tracking-wider">Google Rating</p>
        <p class="text-base font-bold text-ink leading-none">4.9 <span class="text-gold">★</span></p>
      </div>
    </a>

  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    z-index: 200;
    padding: 0.5rem 1.25rem;
    background: white;
    color: var(--color-green-dark);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 0 0 8px 0;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  .skip-link:focus-visible {
    top: 0;
    outline: 2px solid var(--color-green-mid);
    outline-offset: 2px;
  }
</style>
