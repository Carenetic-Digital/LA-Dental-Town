---
const year = new Date().getFullYear();
---

<footer class="bg-teal-dark text-white/80">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Column 1: Brand + Contact -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-9 h-9 bg-green-mid rounded-full flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C9.79 2 8 3.12 7 4.5 6 3.12 4 3 4 5.5 4 8.5 5.5 10 5.5 13c0 2.5.5 7 2.5 7 1.5 0 2-2.5 2.5-4.5h3C14 17.5 14.5 20 16 20c2 0 2.5-4.5 2.5-7 0-3 1.5-4.5 1.5-7.5 0-2.5-2-2.38-3-1C16 3.12 14.21 2 12 2z"/>
            </svg>
          </div>
          <div>
            <p class="font-display font-bold text-white text-base leading-none">LA Dental Town</p>
            <p class="font-body text-[11px] text-white/50 uppercase tracking-wider mt-0.5">East Los Angeles, CA</p>
          </div>
        </div>

        <p class="font-body text-sm leading-relaxed text-white/70 mb-6">
          Family &amp; cosmetic dentistry serving East Los Angeles and surrounding communities.
        </p>

        <ul class="space-y-2.5 text-sm">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-green-mid mt-0.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <span class="text-white/70">5262 E Beverly Blvd<br>East Los Angeles, CA 90022</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-green-mid shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            <a href="tel:+13238870088" class="text-white/70 hover:text-white transition-colors">(323) 887-0088</a>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-green-mid mt-0.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
            </svg>
            <span class="text-white/70">Mon–Fri: 8:30am – 5:30pm<br><span class="text-white/40">Sat–Sun: Closed</span></span>
          </li>
        </ul>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="font-body font-semibold text-white text-sm uppercase tracking-widest mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="footer-link">Home</a></li>
          <li><a href="/contents/appointments/" class="footer-link">Book Appointment</a></li>
          <li><a href="/about/" class="footer-link">About Us</a></li>
          <li><a href="/provider/" class="footer-link">Meet the Doctors</a></li>
          <li><a href="/contents/about/our-office/" class="footer-link">Our Office</a></li>
          <li><a href="/contents/before-after/" class="footer-link">Before &amp; After</a></li>
          <li><a href="/testimonials/" class="footer-link">Testimonials</a></li>
          <li><a href="/blog/" class="footer-link">Blog</a></li>
          <li><a href="/contactus/" class="footer-link">Contact</a></li>
        </ul>
      </div>

      <!-- Column 3: Services -->
      <div>
        <h3 class="font-body font-semibold text-white text-sm uppercase tracking-widest mb-4">Services</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/services/general-family-dentistry/" class="footer-link">General &amp; Family</a></li>
          <li><a href="/services/cosmetic-dentistry/" class="footer-link">Cosmetic Dentistry</a></li>
          <li><a href="/services/dental-implants/" class="footer-link">Dental Implants</a></li>
          <li><a href="/services/oral-surgery/" class="footer-link">Oral Surgery</a></li>
          <li><a href="/services/endodontics/" class="footer-link">Endodontics</a></li>
          <li><a href="/services/pediatric-dentistry/" class="footer-link">Pediatric Dentistry</a></li>
          <li><a href="/services/veneers/" class="footer-link">Veneers</a></li>
          <li><a href="/services/invisalign/" class="footer-link">Invisalign</a></li>
          <li><a href="/services/teeth-whitening/" class="footer-link">Teeth Whitening</a></li>
        </ul>
      </div>

      <!-- Column 4: Patient Resources -->
      <div>
        <h3 class="font-body font-semibold text-white text-sm uppercase tracking-widest mb-4">Patient Resources</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/contents/patient-resources/first-visit/" class="footer-link">First Visit</a></li>
          <li><a href="/contents/patient-resources/financial/" class="footer-link">Financial &amp; Insurance</a></li>
          <li><a href="/contents/patient-resources/patient-forms/" class="footer-link">Patient Forms</a></li>
        </ul>

        <div class="mt-8">
          <h3 class="font-body font-semibold text-white text-sm uppercase tracking-widest mb-4">Walk-Ins Welcome</h3>
          <p class="text-sm text-white/60 leading-relaxed">Most PPO &amp; Denti-Cal accepted.<br>Se Habla Español.</p>
          <a href="/contents/appointments/" class="inline-block mt-4 bg-green-mid hover:bg-green-dark text-white font-body font-semibold text-sm px-5 py-2.5 rounded-full transition-colors duration-200">
            Book Now
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/60">
        <p>Copyright &copy; {year} LA Dental Town. All rights reserved.</p>
        <nav class="flex items-center gap-4" aria-label="Legal links">
          <a href="/your-privacy/" class="hover:text-white/70 transition-colors">Privacy Policy</a>
          <a href="/our-terms/" class="hover:text-white/70 transition-colors">Terms &amp; Conditions</a>
          <a href="/accessibility-statement/" class="hover:text-white/70 transition-colors">Accessibility</a>
          <a href="/contactus/" class="hover:text-white/70 transition-colors">Contact</a>
        </nav>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 120ms;
    font-family: var(--font-body);
    display: inline-block;
  }
  .footer-link:hover {
    color: white;
    text-decoration: none;
  }

  .footer-link:focus-visible {
    outline: 2px solid #3A7D44;
    outline-offset: 2px;
    border-radius: 3px;
  }
</style>
